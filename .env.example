# ---- Backend ----
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
# DB_PATH=/data                             # Railway persistent volume mount. Omit for local dev (defaults to ./data)
# BEHIND_TLS_PROXY=true                     # Set 'true' when behind Railway/nginx TLS termination
# CORS_ORIGINS=https://your-app.vercel.app  # Comma-separated allowed origins. Omit for local dev defaults
# IP_HASH_SALT=<openssl rand -hex 32>       # REQUIRED in production. Used for anonymizing IPs in logs
# ADMIN_SECRET=<openssl rand -hex 32>       # If unset, admin routes return 503

# ---- Frontend (Vite — build-time only, baked into JS bundle) ----
# VITE_API_URL=https://your-api.up.railway.app   # Railway backend URL. Omit for local dev (Vite proxy handles it)
# VITE_APP_URL=https://your-app.vercel.app        # Used for OG image absolute URLs in index.html
